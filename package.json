{
  "name": "recept-4.0",
  "private": true,
  "version": "3.0.72",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:data && vite build",
    "validate:data": "node scripts/validate-data.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:properties": "vitest run tests/unit/calc.properties.test.ts",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:smoke": "playwright test tests/e2e/app-state.spec.ts tests/e2e/renewal-flow.spec.ts",
    "test:lighthouse": "node scripts/lighthouse.mjs",
    "test:all": "vitest run && playwright test tests/e2e",
    "test:visual": "playwright test tests/visual-baseline/regression.spec.ts",
    "build:db": "node scripts/build-product-db.cjs",
    "generate:drugs": "node scripts/generate-drugs.cjs",
    "scrape:interactions": "node scripts/scrape-interactions.cjs",
    "update:interactions": "node scripts/scrape-interactions.cjs --incremental",
    "update:drugs": "node scripts/build-product-db.cjs && node scripts/generate-drugs.cjs",
    "update:all": "node scripts/build-product-db.cjs && node scripts/generate-drugs.cjs && node scripts/scrape-interactions.cjs --incremental",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.0.4",
    "svelte": "^5.55.9",
    "svelte-check": "^4.1.5",
    "typescript": "~6.0",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.7"
  }
}

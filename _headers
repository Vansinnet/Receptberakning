/*
  # Förhindrar MIME-sniffing (browser tolkar aldrig CSS/JS som HTML)
  X-Content-Type-Options: nosniff

  # Tvingar HTTPS och instruerar webbläsaren att minnas det i 2 år
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Skickar ingen Referer-header till externa sidor (t.ex. FASS-länkar)
  Referrer-Policy: no-referrer

  # Stänger av webbläsarfunktioner som verktyget inte behöver
  # Inkluderar moderna fingerprinting- och spårnings-APIs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), interest-cohort=(), browsing-topics=(), attribution-reporting=(), identity-credentials-get=()

  # Förhindrar att sidan bäddas in i en iframe (clickjacking-skydd)
  # frame-ancestors i <meta>-CSP ignoreras av webbläsare per spec — denna header krävs
  X-Frame-Options: DENY

  # Content Security Policy som HTTP-header (starkare än <meta>-taggen i HTML)
  # require-trusted-types-for blockerar DOM-baserad XSS på webbläsarnivå
  # connect-src 'self' tillåter fetch() av lokala JSON-filer (narcotics.json)
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; manifest-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; require-trusted-types-for 'script'; upgrade-insecure-requests

  # Isolerar fönstret från cross-origin-kontexter — skyddar mot Spectre-liknande sidokanalsattacker
  Cross-Origin-Opener-Policy: same-origin

  # Förhindrar att resurser på sidan laddas in av externa ursprung utan explicit tillstånd
  Cross-Origin-Resource-Policy: same-origin

  # Kräver att alla inladdade resurser explicit tillåter cross-origin-delning (CORP-header)
  # Säkert här eftersom appen inte laddar några externa resurser
  Cross-Origin-Embedder-Policy: require-corp

# Strikt cache-policy för HTML-dokumentet — förhindrar att webbläsaren sparar sidan
# till diskcache på delade datorer i klinisk miljö. Gäller enbart index.html;
# statiska resurser (CSS/JS) kan cachas normalt eftersom de inte innehåller patientdata.
/
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/narcotics.json
  Cache-Control: public, max-age=604800
  Content-Type: application/json
